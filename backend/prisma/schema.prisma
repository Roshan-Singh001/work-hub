// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ROLE {
  ORG_Owner
  ORG_Member
  Admin
  Client
  Freelancer
}

model User {
  id                   String   @id @default(uuid())
  first_name           String
  last_name            String
  email                String   @unique
  password             String
  phone                String
  organizationId       String?

  role                 ROLE 
  status               String  @default("pending")     

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization          Organization?
  client                Client?
  member                Org_member?
  freelancer            Freelancer?
}

model Organization {
  org_id        String  @id @default(uuid())
  org_name      String
  ownerId   String  @unique
  owner     User    @relation(fields: [ownerId], references: [id])

  size       String
  country    String
  industry   String
  website    String?
  license_url String
  org_phone      String?
  org_email      String?
  about      String

  createdAt DateTime @default(now())
}

model Org_member {
  id String @id @default(uuid())
  memberId User @relation(fields: [id], references: [id])
  organizationId String
  local_role String

  createdAt DateTime @default(now())
}

model Client {
  client_id String @id @default(uuid())
  user   User   @relation(fields: [client_id], references: [id])

  org_name String?
  country String
  phone String
}

model Freelancer {
  freelancer_id String @id @default(uuid())
  user   User   @relation(fields: [freelancer_id], references: [id])

  title String
  about String
  country String
  skills_category String
  resume_url String
}
