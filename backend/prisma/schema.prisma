// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ROLE {
  ORG_Owner
  Admin
  Employee
  Client
  Freelancer
}

model User {
  id                   String   @id @default(uuid())
  first_name           String
  last_name            String
  email                String   @unique
  password             String
  phone                String
  organizationId       String?
  organization         Organization? @relation(fields: [organizationId], references: [org_id])

  role                 ROLE      

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  is_owns_org          Organization[] @relation("owns")
}

model Organization {
  org_id        String  @id @default(uuid())
  org_name      String
  ownerId   String  @unique
  owner     User    @relation("owns",fields: [ownerId], references: [id])
  password   String

  size       String
  country    String
  industry   String
  website    String?
  org_phone      String?
  org_email      String?
  about      String

  employee   User[]

  createdAt DateTime @default(now())
}

model Org_member {
  id String @id @default(uuid())
  role String

  createdAt DateTime @default(now())
}

model Client {
  id String @id @default(uuid())
  first_name String
  last_name String
  email String @unique
  phone String @unique
  org_name String?

}
