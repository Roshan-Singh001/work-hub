// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ROLE {
  ORG_Owner
  ORG_Member
  Admin
  Client
  Freelancer
}

enum ORG_ROLE {
  Owner
  Admin
  Manager
  Member
}

enum Visibility {
  ORGANIZATION
  FREELANCER
  BOTH
}

enum AssignedType {
  FREELANCER
  ORGANIZATION
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  DELAYED
  COMPLETED
  CANCELLED
}

enum TaskType {
  INTERNAL
  OUTSOURCED
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum ProjectType {
  FIXED
  HOURLY
}

model Admin {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  phone    String

  createdAt DateTime @default(now())

  AdminAnnouncements AdminAnnouncement[]
}

model User {
  id             String  @id @default(uuid())
  first_name     String
  last_name      String
  email          String  @unique
  password       String
  phone          String
  organizationId String?

  role   ROLE
  status String @default("Pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization?
  client         Client?
  member         Org_member?
  freelancer     Freelancer?
  projectApplications   ProjectApplication[] @relation("FreelancerApplications")
  taskApplications TaskApplication[]
  reportsMade Report[]
  reportsReceived Report[] @relation("ReportedUser")
  feedbacks Feedback[]
}

model Organization {
  org_id   String @id @default(uuid())
  org_name String
  org_logo_url String?
  ownerId  String @unique
  owner    User   @relation(fields: [ownerId], references: [id])

  size        String
  country     String
  industry    String
  website     String?
  license_url String
  org_phone   String?
  org_email   String?
  about       String   @db.Text
  createdAt   DateTime @default(now())

  rating Float @default(0)

  members Org_member[]
  orgApplications ProjectApplication[]
  orgAnnouncements OrganizationAnnouncement[]
}

model Org_member {
  id String @id @default(uuid())

  userId         String @unique
  user           User   @relation(fields: [userId], references: [id])
  organizationId String

  role           ORG_ROLE @default(Member)
  status         String   @default("active")
  jobTitle       String?
  jobDescription String?  @db.Text

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [org_id])
}

model Client {
  client_id String @id @default(uuid())
  user      User   @relation(fields: [client_id], references: [id])
  client_dp_url String?

  org_name String?
  country  String
  rating   Float  @default(0)

  clientProjects Project[] @relation("ClientProjects")
}

model Freelancer {
  freelancer_id String @id @default(uuid())
  user          User   @relation(fields: [freelancer_id], references: [id])
  freelancer_dp_url String?

  title           String
  about           String
  country         String
  skills_category String
  skills          Skill[]
  experience      String? @default("")
  hourly_rate     Float? @default(0)
  resume_url      String
  rating          Float  @default(0)
}

model Skill {
  id   String @id @default(uuid())
  name String @unique

  projects Project[]
  freelancers Freelancer[]
}

model Industry {
  id   String @id @default(uuid())
  name String @unique

  projects Project[]
}

model Project {
  project_id   String   @id @default(uuid())
  title        String
  shortDesc    String?
  description  String   @db.Text
  assignedToId String?
  assignedAt   DateTime?
  assignedType AssignedType?
  clientId     String

  client Client @relation("ClientProjects", fields: [clientId], references: [client_id])

  visibility Visibility    @default(BOTH)
  status     ProjectStatus @default(OPEN)
  minBudget  Float
  maxBudget  Float
  finalPrice Float?
  deadline   DateTime

  experienceLevel ExperienceLevel?
  projectType ProjectType

  industry Industry[]
  skills   Skill[]
  tasks    ProjectTask[]

  startDate      DateTime?
  completionDate DateTime?
  progress       Int      @default(0)
  files          Json?

  review String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications ProjectApplication[]
}

model ProjectTask {
  task_id     String @id @default(uuid())
  title       String
  description String

  projectId String
  project   Project @relation(fields: [projectId], references: [project_id])

  assignments TaskAssignment[]

  status String @default("open")
  progress Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review String? @db.Text

  applications TaskApplication[]
}

model TaskAssignment {
  id String @id @default(uuid())

  taskId String
  userId String

  role   String?
  status String  @default("assigned")

  assignedAt DateTime @default(now())

  task ProjectTask @relation(fields: [taskId], references: [task_id])
}

enum ApplicantType {
  FREELANCER
  ORGANIZATION
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ProjectApplication {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [project_id])

  freelancerId String?
  freelancer   User? @relation("FreelancerApplications", fields: [freelancerId], references: [id])

  orgId String?
  organization Organization? @relation(fields: [orgId], references: [org_id])
  applicantType ApplicantType

  coverLetter String? @db.Text
  proposedPrice Float
  status       ApplicationStatus  @default(PENDING)
  appliedAt DateTime @default(now())
}

model TaskApplication {
  id String @id @default(uuid())

  taskId String
  task   ProjectTask @relation(fields: [taskId], references: [task_id])

  freelancerId String
  freelancer   User @relation(fields: [freelancerId], references: [id])

  coverLetter   String? @db.Text
  proposedPrice Float
  status        ApplicationStatus @default(PENDING)

  appliedAt DateTime @default(now())
}

model AdminAnnouncement {
  id String @id @default(uuid())

  adminId String
  admin   Admin @relation(fields: [adminId], references: [id])

  title String
  content String @db.Text

  createdAt DateTime @default(now())
}

model OrganizationAnnouncement {
  id String @id @default(uuid())

  organizationId String
  organization Organization @relation(fields: [organizationId], references: [org_id])

  title String
  content String @db.Text

  createdAt DateTime @default(now())
}

model Report {
  id String @id @default(uuid())

  reporterId String
  reporter   User @relation(fields: [reporterId], references: [id])

  reportedUserId String
  reportedUser   User @relation("ReportedUser", fields: [reportedUserId], references: [id])

  reason String @db.Text
  status String @default("open")

  createdAt DateTime @default(now())
}

model Feedback {
  id String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id])

  message String @db.Text

  createdAt DateTime @default(now())
}
